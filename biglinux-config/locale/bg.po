# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 76
msgid "Welcome to Restore Settings"
msgstr "Добре дошли в Възстановяване на настройки"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 83
msgid "Easily restore, backup, and manage application settings on BigLinux."
msgstr "Лесно възстановявайте, архивирайте и управлявайте настройки на приложения в BigLinux."
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 104
msgid "Restore BigLinux Defaults"
msgstr "Възстановяване на подразбиращите се настройки на BigLinux"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 106
msgid ""
"Reset any application to the BigLinux default\n"
"settings with a single click using /etc/skel."
msgstr ""
"Нулирайте всяко приложение до настройките по подразбиране на BigLinux с едно кликване, използвайки "
"/etc/skel."
# 
# #-#-#-#-#  biglinux-config.pot (biglinux-config)  #-#-#-#-#
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 118
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/backup_dialog.py, line: 43
msgid "Export Settings"
msgstr "Настройки за експортиране"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 120
msgid ""
"Back up dotfiles for multiple applications\n"
"into a single compressed .tar.gz archive."
msgstr "Резервно копиране на dotfiles за множество приложения в един компресиран .tar.gz архив."
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 125
msgid "Search Across All Apps"
msgstr "Търсене в всички приложения"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 127
msgid ""
"Quickly find any installed application\n"
"using the integrated search in the header bar."
msgstr ""
"Бързо намерете всяко инсталирано приложение, използвайки интегрираното търсене в лентата с "
"инструменти."
# 
# #-#-#-#-#  biglinux-config.pot (biglinux-config)  #-#-#-#-#
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 141
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/backup_dialog.py, line: 362
msgid "Import Settings"
msgstr "Импорт на настройки"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 143
msgid ""
"Restore previously exported settings from\n"
"a .tar.gz backup with per-application selection."
msgstr "Възстановете преди това експортирани настройки от .tar.gz резервно копие с избор по приложение."
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 155
msgid "Flatpak Support"
msgstr "Поддръжка на Flatpak"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 157
msgid ""
"View and manage Flatpak application\n"
"settings alongside native packages."
msgstr "Прегледайте и управлявайте настройките на Flatpak приложенията заедно с местните пакети."
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 162
msgid "Organized by Category"
msgstr "Организирано по категория"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 164
msgid ""
"Browse applications grouped by category:\n"
"browsers, multimedia, office, system, and more."
msgstr "Прегледайте приложения, групирани по категории: браузъри, мултимедия, офис, система и други."
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 183
msgid "Show this dialog on startup"
msgstr "Покажи този диалог при стартиране"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 200
msgid "Let's Start"
msgstr "Нека започнем"
