msgid "Import Settings"
msgstr "Importar Configuraciones"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 143
msgid ""
"Restore previously exported settings from\n"
"a .tar.gz backup with per-application selection."
msgstr "Restaura la configuración exportada previamente de un respaldo .tar.gz con selección por aplicación."
