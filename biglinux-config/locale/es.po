msgid "Export Settings"
msgstr "Configuración de exportación"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 120
msgid ""
"Back up dotfiles for multiple applications\n"
"into a single compressed .tar.gz archive."
msgstr ""
"Hacer una copia de seguridad de los archivos de configuración para múltiples aplicaciones en un "
"único archivo comprimido .tar.gz."
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 125
msgid "Search Across All Apps"
msgstr "Buscar en todas las aplicaciones"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 127
msgid ""
"Quickly find any installed application\n"
"using the integrated search in the header bar."
msgstr ""
"Encuentra rápidamente cualquier aplicación instalada utilizando la búsqueda integrada en la barra "
"de encabezado."
# 
# #-#-#-#-#  biglinux-config.pot (biglinux-config)  #-#-#-#-#
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 141
