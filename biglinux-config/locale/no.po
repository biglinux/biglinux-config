# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 136
msgid ""
"Restore previously exported settings from\n"
"a .tar.gz backup with per-application selection."
msgstr ""
"Gjenopprett tidligere eksporterte innstillinger fra en .tar.gz sikkerhetskopi med valg per "
"applikasjon."
