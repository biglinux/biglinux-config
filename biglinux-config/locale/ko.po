# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 76
msgid "Welcome to Restore Settings"
msgstr "설정 복원에 오신 것을 환영합니다"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 83
msgid "Easily restore, backup, and manage application settings on BigLinux."
msgstr "BigLinux에서 애플리케이션 설정을 쉽게 복원, 백업 및 관리하세요."
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 104
msgid "Restore BigLinux Defaults"
msgstr "빅리눅스 기본값 복원"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 106
msgid ""
"Reset any application to the BigLinux default\n"
"settings with a single click using /etc/skel."
msgstr "단일 클릭으로 /etc/skel을 사용하여 모든 애플리케이션을 BigLinux 기본 설정으로 재설정합니다."
# 
# #-#-#-#-#  biglinux-config.pot (biglinux-config)  #-#-#-#-#
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 111
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/backup_dialog.py, line: 39
msgid "Export Settings"
msgstr "내보내기 설정"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 113
msgid ""
"Back up dotfiles for multiple applications\n"
"into a single compressed .tar.gz archive."
msgstr "여러 응용 프로그램의 dotfiles를 단일 압축 .tar.gz 아카이브로 백업합니다."
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 118
msgid "Search Across All Apps"
msgstr "모든 앱에서 검색"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 120
msgid ""
"Quickly find any installed application\n"
"using the integrated search in the header bar."
msgstr "헤더 바에 통합 검색을 사용하여 설치된 애플리케이션을 빠르게 찾으세요."
# 
# #-#-#-#-#  biglinux-config.pot (biglinux-config)  #-#-#-#-#
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 134
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/backup_dialog.py, line: 480
msgid "Import Settings"
msgstr "설정 가져오기"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 136
msgid ""
"Restore previously exported settings from\n"
"a .tar.gz backup with per-application selection."
msgstr "애플리케이션별 선택이 가능한 .tar.gz 백업에서 이전에 내보낸 설정을 복원합니다."
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 141
msgid "Flatpak Support"
msgstr "Flatpak 지원"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 143
msgid ""
"View and manage Flatpak application\n"
"settings alongside native packages."
msgstr "네이티브 패키지와 함께 Flatpak 애플리케이션 설정을 보고 관리합니다."
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 147
msgid "Organized by Category"
msgstr "카테고리별 정리"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 149
msgid ""
"Browse applications grouped by category:\n"
"browsers, multimedia, office, system, and more."
msgstr "카테고리별로 그룹화된 애플리케이션 탐색: 브라우저, 멀티미디어, 오피스, 시스템 등."
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 167
msgid "Show this dialog on startup"
msgstr "시작 시 이 대화 상자 표시"
# 
# File: biglinux-config/biglinux-config/usr/share/biglinux/biglinux-config/ui/welcome_dialog.py, line: 184
msgid "Let's Start"
msgstr "시작합시다"
